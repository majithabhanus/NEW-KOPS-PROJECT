pipeline {
    agent any

    environment {
        IMAGE_NAME = "majithas/go-todo"
        K8S_DIR = "server/k8s"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/majithabhanus/NEW-KOPS-PROJECT.git',
                    credentialsId: 'github-cred'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${IMAGE_NAME}:latest")
                }
            }
        }

        stage('Login to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-cred-id',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                sh '''
                docker push ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Setup kubeconfig for Jenkins') {
            steps {
                sh '''
                mkdir -p $HOME/.kube
                sudo cp /home/ubuntu/.kube/config $HOME/.kube/config
                sudo chown jenkins:jenkins $HOME/.kube/config
                '''
            }
        }

        stage('Verify Cluster Access') {
            steps {
                sh '''
                kubectl get nodes
                '''
            }
        }

        stage('Deploy Kubernetes Manifests') {
            steps {
                sh '''
                kubectl apply -f ${K8S_DIR}/
                '''
            }
        }

        stage('Update Deployment Image') {
            steps {
                sh '''
                kubectl set image deployment/backend backend=${IMAGE_NAME}:latest || true
                kubectl set image deployment/frontend frontend=${IMAGE_NAME}:latest || true
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                kubectl get pods -o wide
                kubectl get svc
                kubectl get ingress
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Application successfully deployed to Kubernetes"
        }
        failure {
            echo "❌ Pipeline failed. Check logs."
        }
    }
}
